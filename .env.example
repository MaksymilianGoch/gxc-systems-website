# Ollama — lokales KI-Modell für den Chat-Widget
# Ollama muss laufen: https://ollama.com — Standard braucht keine Änderung
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=gemma4

# n8n Webhook — server-side only, never exposed to client
# REVIEW: Eintragen sobald n8n-Instanz konfiguriert ist
N8N_WEBHOOK_URL=https://your-n8n.com/webhook/contact-gxc

# Site-URL (für Schema.org und Webhook-Source-Tracking)
# REVIEW: Auf echte Domain anpassen
NEXT_PUBLIC_SITE_URL=https://gxc-systems.com

# Plausible Analytics Domain (DSGVO-konform, kein Cookie-Banner nötig)
# REVIEW: Domain nach Plausible-Setup eintragen
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=gxc-systems.com
